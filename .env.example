# Climate Intelligence Platform - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Connection
DATABASE_URL=postgresql://climate_app:climate_app@localhost:5432/climate_platform

# SQL Query Logging (for debugging)
SQL_ECHO=false

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
ENVIRONMENT=development

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

REDIS_URL=redis://localhost:6379/0

# ============================================================================
# REGULATORY MONITORING (CRCS)
# ============================================================================

# Web Scraping
SCRAPER_USER_AGENT=Mozilla/5.0 (Climate Intelligence Platform)
SCRAPER_TIMEOUT=30

# News Feed Monitoring
NEWS_API_ENABLED=true
NEWS_API_KEY=your_news_api_key_here

# Change Detection Daily Time (UTC)
CHANGE_DETECTION_DAILY_TIME=02:00

# ============================================================================
# CLIMATE DATA INTEGRATION
# ============================================================================

# ECMWF ERA5 Data (Copernicus CDS)
COPERNICUS_CDS_API_KEY=your_copernicus_cds_key_here
COPERNICUS_CDS_TIMEOUT=600

# Copernicus Scihub
COPERNICUS_SCIHUB_USER=your_scihub_email@example.com
COPERNICUS_SCIHUB_PASSWORD=your_scihub_password

# ============================================================================
# GEOGRAPHIC DATA
# ============================================================================

# H3 Resolution (8 ~= 0.7 km²)
H3_RESOLUTION=8

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# JWT Secret Key
SECRET_KEY=your_super_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# MONITORING
# ============================================================================

# Sentry (error tracking)
SENTRY_DSN=

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

DEBUG=false
CREATE_TEST_DATA=false
